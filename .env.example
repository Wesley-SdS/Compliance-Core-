# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=compliancecore
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Vektus (RAG/OCR)
VEKTUS_BASE_URL=https://vektus.adalink.com
VEKTUS_API_KEY=vkt_...
VEKTUS_WEBHOOK_SECRET=secret_...
VEKTUS_PROJECT_ID=proj_estetik

# Cloudflare R2 Storage
R2_ENDPOINT=https://...r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=compliancecore
R2_PUBLIC_URL=https://...r2.dev

# Auth (Better Auth)
BETTER_AUTH_SECRET=           # gerar com: openssl rand -hex 32
BETTER_AUTH_URL=http://localhost:3100  # URL base do frontend (onde /api/auth/* roda)

# Social Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email (para magic link e reset password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@compliancecore.com
RESEND_API_KEY=

# App
PORT=3001
CORS_ORIGIN=http://localhost:3100
NODE_ENV=development
VERTICAL=estetik
SELF_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
