{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@compliancecore/sdk": ["packages/sdk/src"],
      "@compliancecore/ui": ["packages/ui/src"],
      "@compliancecore/shared": ["packages/shared/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
